# ML Inference Platform Lab - Environment Configuration

# Application
APP_NAME=ml-inference-platform-lab
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Model Registry
MODEL_REGISTRY_PATH=models/model_registry.json

# Canary Deployment
CANARY_PERCENTAGE=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Prometheus
METRICS_ENABLED=true

# Drift Detection
DRIFT_THRESHOLD=0.3

# Optional AI explanation integration
# Never commit a real key. Put the real value in .env only.
DEEPSEEK_API_KEY=
